<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== PALETTE (MSI black / red) ==================== -->
    <Color x:Key="BgColor">#FF0A0A0C</Color>
    <Color x:Key="SurfaceColor">#FF141417</Color>
    <Color x:Key="SurfaceAltColor">#FF1C1B1D</Color>
    <Color x:Key="SurfaceHighColor">#FF201F21</Color>
    <Color x:Key="BorderColor">#FF2A2A2F</Color>
    <Color x:Key="BorderDimColor">#FF1E1E22</Color>
    <Color x:Key="TextColor">#FFF2F3F5</Color>
    <Color x:Key="TextMutedColor">#FF8A8F98</Color>
    <Color x:Key="RedColor">#FFE4002B</Color>
    <Color x:Key="RedGlowColor">#FFFF1E2D</Color>
    <Color x:Key="PinkColor">#FFFFB3AF</Color>
    <Color x:Key="SuccessColor">#FF35D07F</Color>
    <Color x:Key="WarnColor">#FFFFB020</Color>

    <SolidColorBrush x:Key="Bg" Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="Surface" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceAlt" Color="{StaticResource SurfaceAltColor}" />
    <SolidColorBrush x:Key="SurfaceHigh" Color="{StaticResource SurfaceHighColor}" />
    <SolidColorBrush x:Key="Border" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderDim" Color="{StaticResource BorderDimColor}" />
    <SolidColorBrush x:Key="Text" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="TextMuted" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="Red" Color="{StaticResource RedColor}" />
    <SolidColorBrush x:Key="RedGlow" Color="{StaticResource RedGlowColor}" />
    <SolidColorBrush x:Key="Pink" Color="{StaticResource PinkColor}" />
    <SolidColorBrush x:Key="Success" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="Warn" Color="{StaticResource WarnColor}" />
    <!-- back-compat aliases -->
    <SolidColorBrush x:Key="Accent" Color="{StaticResource RedColor}" />
    <SolidColorBrush x:Key="Danger" Color="{StaticResource RedColor}" />

    <LinearGradientBrush x:Key="AccentGrad" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource RedColor}" Offset="0" />
        <GradientStop Color="{StaticResource RedGlowColor}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeroGrad" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF161417" Offset="0" />
        <GradientStop Color="#FF0E0E10" Offset="1" />
    </LinearGradientBrush>

    <!-- red LED glow for active/critical elements -->
    <DropShadowEffect x:Key="RedGlowFx" Color="{StaticResource RedGlowColor}" BlurRadius="14"
                      ShadowDepth="0" Opacity="0.55" />

    <!-- subtle diagonal carbon texture for the sidebar -->
    <DrawingBrush x:Key="Carbon" TileMode="Tile" Viewport="0,0,8,8" ViewportUnits="Absolute"
                  Viewbox="0,0,8,8" ViewboxUnits="Absolute">
        <DrawingBrush.Drawing>
            <GeometryDrawing Geometry="M0,8 L8,0">
                <GeometryDrawing.Pen>
                    <Pen Thickness="1" Brush="#0AFFFFFF" />
                </GeometryDrawing.Pen>
            </GeometryDrawing>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- ==================== FONTS ==================== -->
    <FontFamily x:Key="FontHead">Bahnschrift Condensed, Bahnschrift, Segoe UI Semibold</FontFamily>
    <FontFamily x:Key="FontMetric">Bahnschrift SemiBold, Bahnschrift, Segoe UI Semibold</FontFamily>
    <FontFamily x:Key="FontLabel">Bahnschrift, Segoe UI</FontFamily>
    <FontFamily x:Key="FontBody">Segoe UI</FontFamily>
    <FontFamily x:Key="FontMono">Consolas</FontFamily>

    <!-- ==================== TEXT STYLES ==================== -->
    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontHead}" />
        <Setter Property="Foreground" Value="{StaticResource Text}" />
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style x:Key="H2" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontHead}" />
        <Setter Property="Foreground" Value="{StaticResource Text}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style x:Key="Label" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontLabel}" />
        <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="Value" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontBody}" />
        <Setter Property="Foreground" Value="{StaticResource Text}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style x:Key="Metric" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMetric}" />
        <Setter Property="Foreground" Value="{StaticResource Text}" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <!-- ==================== CARDS ==================== -->
    <!-- accent card: sharp corners + 2px red top line -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Red}" />
        <Setter Property="BorderThickness" Value="0,2,0,0" />
        <Setter Property="Padding" Value="20" />
    </Style>
    <!-- neutral panel: 1px dim border all around -->
    <Style x:Key="Panel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderDim}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="20" />
    </Style>
    <!-- metric tile -->
    <Style x:Key="Tile" TargetType="Border">
        <Setter Property="Background" Value="#FF101013" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderDim}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <!-- ==================== STATUS CHIP ==================== -->
    <Style x:Key="Chip" TargetType="Border">
        <Setter Property="Background" Value="#FF101013" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderDim}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,7" />
    </Style>

    <!-- ==================== NAV (RadioButton) ==================== -->
    <Style x:Key="NavButton" TargetType="RadioButton">
        <Setter Property="FontFamily" Value="{StaticResource FontLabel}" />
        <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Height" Value="44" />
        <Setter Property="Margin" Value="12,2" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="bd" Background="Transparent" Padding="14,0"
                            BorderBrush="{StaticResource Red}" BorderThickness="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="icon" Text="{TemplateBinding Tag}"
                                       FontFamily="Segoe MDL2 Assets" FontSize="15" VerticalAlignment="Center" />
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#FF17161A" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#22E4002B" />
                            <Setter TargetName="bd" Property="BorderThickness" Value="3,0,0,0" />
                            <Setter TargetName="bd" Property="Effect" Value="{StaticResource RedGlowFx}" />
                            <Setter Property="Foreground" Value="{StaticResource Pink}" />
                            <Setter TargetName="icon" Property="Foreground" Value="{StaticResource Red}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== PRIMARY BUTTON ==================== -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource FontHead}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{StaticResource Red}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource RedGlow}" />
                            <Setter TargetName="bd" Property="Effect" Value="{StaticResource RedGlowFx}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.35" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== GHOST BUTTON ==================== -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource FontLabel}" />
        <Setter Property="Foreground" Value="{StaticResource Text}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="#FF101013"
                            BorderBrush="{StaticResource BorderDim}" BorderThickness="1" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Red}" />
                            <Setter TargetName="bd" Property="Effect" Value="{StaticResource RedGlowFx}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.35" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== PROGRESS BAR ==================== -->
    <Style x:Key="Bar" TargetType="ProgressBar">
        <Setter Property="Height" Value="6" />
        <Setter Property="Minimum" Value="0" />
        <Setter Property="Maximum" Value="100" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{StaticResource BorderDim}">
                        <Grid>
                            <Border x:Name="PART_Track" />
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                    Background="{StaticResource AccentGrad}" Effect="{StaticResource RedGlowFx}" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== SCROLLBAR (thin) ==================== -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="{StaticResource Border}" Margin="2,0" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
