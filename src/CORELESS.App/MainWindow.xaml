<Window x:Class="Coreless.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:conv="clr-namespace:Coreless.Converters"
        xmlns:ctl="clr-namespace:Coreless.Controls"
        Title="CORELESS" Height="860" Width="1360"
        MinHeight="640" MinWidth="1040"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}"
        Foreground="{StaticResource Text}"
        FontFamily="{StaticResource FontBody}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6"
                            GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolVis" />
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />

        <!-- ===== nav item (component ListBox) ===== -->
        <Style x:Key="NavItem" TargetType="ListBoxItem">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="12,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="Transparent" Padding="14,9"
                                BorderBrush="{StaticResource Red}" BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="badge" Width="30" Height="24" Background="#FF101013"
                                        BorderBrush="{StaticResource BorderDim}" BorderThickness="1">
                                    <TextBlock Text="{Binding ShortCode}" Foreground="{StaticResource TextMuted}"
                                               FontFamily="{StaticResource FontLabel}" FontSize="9" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock x:Name="nm" Grid.Column="1" Text="{Binding Name}" Margin="12,0,0,0"
                                           Foreground="{StaticResource TextMuted}" FontFamily="{StaticResource FontLabel}"
                                           FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF17161A" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22E4002B" />
                                <Setter TargetName="bd" Property="BorderThickness" Value="3,0,0,0" />
                                <Setter TargetName="nm" Property="Foreground" Value="{StaticResource Pink}" />
                                <Setter TargetName="badge" Property="BorderBrush" Value="{StaticResource Red}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== sensor row ===== -->
        <DataTemplate x:Key="SensorRowTemplate">
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextMuted}"
                           FontSize="12.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" FontFamily="{StaticResource FontMono}">
                        <Run Text="{Binding Value, Mode=OneWay}" Foreground="{StaticResource Text}" FontWeight="Bold" FontSize="13" />
                        <Run Text="{Binding Unit, Mode=OneWay}" Foreground="{StaticResource TextMuted}" FontSize="11" />
                    </TextBlock>
                    <TextBlock Foreground="#55FFFFFF" FontFamily="{StaticResource FontMono}" FontSize="10.5"
                               Margin="14,0,0,0" VerticalAlignment="Center">
                        <Run Text="▼" /><Run Text="{Binding Min, Mode=OneWay}" />
                        <Run Text="  ▲" /><Run Text="{Binding Max, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- ===== sensor group ===== -->
        <DataTemplate x:Key="GroupTemplate">
            <Border Style="{StaticResource Panel}" Margin="0,0,0,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="4" Height="14" Background="{StaticResource Red}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Title}" FontFamily="{StaticResource FontHead}" FontSize="14"
                                   FontWeight="Bold" Foreground="{StaticResource Pink}" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding Sensors}" ItemTemplate="{StaticResource SensorRowTemplate}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ===== sub-component ===== -->
        <DataTemplate x:Key="SubComponentTemplate">
            <StackPanel Margin="0,0,0,4">
                <TextBlock Text="{Binding Name}" Foreground="{StaticResource Red}" FontFamily="{StaticResource FontHead}"
                           FontSize="13" FontWeight="Bold" Margin="2,4,0,10" />
                <ItemsControl ItemsSource="{Binding Groups}" ItemTemplate="{StaticResource GroupTemplate}" />
            </StackPanel>
        </DataTemplate>

        <!-- ===== overview component card ===== -->
        <DataTemplate x:Key="CardTemplate">
            <Button Command="{Binding DataContext.SelectComponentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}" Cursor="Hand" Margin="0,0,18,18">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Style="{StaticResource Card}" Width="352">
                            <StackPanel>
                                <!-- header -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="44" Height="44" Background="#FF101013"
                                            BorderBrush="{StaticResource BorderDim}" BorderThickness="1">
                                        <TextBlock Text="{Binding ShortCode}" Foreground="{StaticResource Red}"
                                                   FontFamily="{StaticResource FontLabel}" FontWeight="Bold" FontSize="12"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Category}" Foreground="{StaticResource TextMuted}"
                                                   FontFamily="{StaticResource FontLabel}" FontSize="11" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text}"
                                                   FontFamily="{StaticResource FontHead}" FontSize="17" FontWeight="Bold"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="250" HorizontalAlignment="Left" />
                                    </StackPanel>
                                </Grid>

                                <!-- metric tiles -->
                                <UniformGrid Rows="1" Margin="0,16,0,0">
                                    <Border Style="{StaticResource Tile}" Margin="0,0,8,0"
                                            Visibility="{Binding HasTemp, Converter={StaticResource BoolVis}}">
                                        <StackPanel>
                                            <TextBlock Text="TEMP °C" Style="{StaticResource Label}" FontSize="10" />
                                            <TextBlock Text="{Binding TempHeadline.Value, Mode=OneWay}" Style="{StaticResource Metric}"
                                                       FontSize="26" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource Tile}" Margin="0,0,8,0"
                                            Visibility="{Binding HasLoad, Converter={StaticResource BoolVis}}">
                                        <StackPanel>
                                            <TextBlock Text="LOAD %" Style="{StaticResource Label}" FontSize="10" />
                                            <TextBlock Text="{Binding LoadHeadline.Value, Mode=OneWay}" Style="{StaticResource Metric}"
                                                       FontSize="26" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource Tile}"
                                            Visibility="{Binding HasClock, Converter={StaticResource BoolVis}}">
                                        <StackPanel>
                                            <TextBlock Text="CLOCK MHz" Style="{StaticResource Label}" FontSize="10" />
                                            <TextBlock Text="{Binding ClockHeadline.Value, Mode=OneWay}" Style="{StaticResource Metric}"
                                                       FontSize="26" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <!-- footer -->
                                <Grid Margin="0,14,0,0">
                                    <TextBlock Foreground="{StaticResource TextMuted}" FontFamily="{StaticResource FontLabel}"
                                               FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center">
                                        <Run Text="{Binding SensorCount, Mode=OneWay}" /><Run Text=" CAPTEURS" />
                                    </TextBlock>
                                    <TextBlock Text="DÉTAILS ›" Foreground="{StaticResource Red}" FontFamily="{StaticResource FontLabel}"
                                               FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Effect" Value="{StaticResource RedGlowFx}" />
                                <Setter TargetName="bd" Property="Background" Value="#FF17161A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <!-- ===== benchmark result card ===== -->
        <DataTemplate x:Key="BenchResultTemplate">
            <Border Style="{StaticResource Card}" Width="330" Margin="0,0,18,18" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontFamily="{StaticResource FontHead}" FontSize="16"
                               FontWeight="Bold" Foreground="{StaticResource Text}" />
                    <TextBlock Text="{Binding ScoreLabel}" Style="{StaticResource Label}" Margin="0,12,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="{Binding ScoreValue, Mode=OneWay}" Style="{StaticResource Metric}"
                                   FontSize="34" Foreground="{StaticResource Pink}" />
                        <TextBlock Text="{Binding ScoreUnit, Mode=OneWay}" Foreground="{StaticResource TextMuted}"
                                   FontFamily="{StaticResource FontLabel}" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Bottom" Margin="6,0,0,5" />
                    </StackPanel>
                    <Border Height="1" Background="{StaticResource BorderDim}" Margin="0,14,0,10" />
                    <ItemsControl ItemsSource="{Binding Details}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="5" Height="5" Background="{StaticResource Red}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Label}" Foreground="{StaticResource TextMuted}"
                                               FontSize="12" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="2" Text="{Binding Value}" Foreground="{StaticResource Text}"
                                               FontFamily="{StaticResource FontMono}" FontSize="12" FontWeight="Bold" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <!-- ==================== LAYOUT ==================== -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== TITLE BAR ===== -->
        <Border Grid.Row="0" Background="{StaticResource Bg}" BorderBrush="{StaticResource BorderDim}"
                BorderThickness="0,0,0,1" MouseDown="TitleBar_MouseDown">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <Border Width="10" Height="22" Background="{StaticResource Red}" Effect="{StaticResource RedGlowFx}" />
                    <TextBlock Text="CORELESS" Margin="12,0,0,0" VerticalAlignment="Center"
                               FontFamily="{StaticResource FontHead}" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource Pink}" />
                    <Border Width="1" Height="20" Background="{StaticResource BorderDim}" Margin="14,0" />
                    <TextBlock Text="HARDWARE MONITOR" VerticalAlignment="Center"
                               FontFamily="{StaticResource FontLabel}" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="&#xE921;" Click="Minimize_Click" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Width="46" Height="34" Foreground="{StaticResource Text}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="mb" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="mb" Property="Background" Value="{StaticResource SurfaceAlt}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="&#xE922;" Click="Maximize_Click" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Width="46" Height="34" Foreground="{StaticResource Text}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="xb" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="xb" Property="Background" Value="{StaticResource SurfaceAlt}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="&#xE8BB;" Click="Close_Click" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Width="46" Height="34" Margin="0,0,4,0" Foreground="{StaticResource Text}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="cb" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="cb" Property="Background" Value="{StaticResource Red}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== BODY ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="252" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ===== SIDEBAR ===== -->
            <Border Grid.Column="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource BorderDim}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Rectangle Fill="{StaticResource Carbon}" IsHitTestVisible="False" />
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- section header -->
                        <StackPanel Grid.Row="0" Margin="24,20,0,14">
                            <TextBlock Text="MONITORING" FontFamily="{StaticResource FontHead}" FontSize="15"
                                       FontWeight="Bold" Foreground="{StaticResource Pink}" />
                            <TextBlock Text="SYSTEM STATUS" Style="{StaticResource Label}" FontSize="10" Margin="0,2,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Row="1">
                            <RadioButton Content="Vue d'ensemble" Style="{StaticResource NavButton}"
                                         Tag="&#xE9D2;" Command="{Binding ShowOverviewCommand}"
                                         IsChecked="{Binding ShowOverview, Mode=OneWay}" />
                            <RadioButton Content="Benchmarks &amp; Stress" Style="{StaticResource NavButton}"
                                         Tag="&#xE9D9;" Command="{Binding ShowBenchmarksCommand}"
                                         IsChecked="{Binding ShowBenchmarks, Mode=OneWay}" />
                        </StackPanel>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="COMPOSANTS" Style="{StaticResource Label}" FontSize="10"
                                           Margin="26,4,0,8" />
                                <ListBox ItemsSource="{Binding Components}"
                                         SelectedItem="{Binding SelectedComponent, Mode=TwoWay}"
                                         ItemContainerStyle="{StaticResource NavItem}"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="3" BorderBrush="{StaticResource BorderDim}" BorderThickness="0,1,0,0" Padding="18,12">
                            <StackPanel>
                                <TextBlock Text="{Binding Status}" Style="{StaticResource Label}"
                                           TextWrapping="Wrap" FontSize="11" FontWeight="Normal" />
                                <TextBlock Margin="0,6,0,0" FontFamily="{StaticResource FontMono}" FontSize="10.5">
                                    <Run Text="MAJ " Foreground="#FF8A8F98" /><Run Text="{Binding LastUpdated, Mode=OneWay}" Foreground="{StaticResource Red}" />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- ===== CONTENT ===== -->
            <Grid Grid.Column="1" ClipToBounds="True">

                <!-- GPU stress load surface -->
                <Canvas x:Name="GpuSurface" Visibility="Collapsed" IsHitTestVisible="False" Opacity="0.35" />

                <!-- OVERVIEW -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30,26"
                              Visibility="{Binding ShowOverview, Converter={StaticResource BoolVis}}">
                    <StackPanel>
                        <!-- HERO -->
                        <TextBlock Text="{Binding MachineName}" Style="{StaticResource H1}" />
                        <TextBlock Text="{Binding OsDescription}" Style="{StaticResource Label}" FontSize="13"
                                   FontWeight="Normal" Margin="0,4,0,0" />
                        <Border Height="2" Background="{StaticResource AccentGrad}" Margin="0,14,0,0" />

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ItemsControl ItemsSource="{Binding QuickStats}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Chip}" Margin="0,0,10,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Label}" Style="{StaticResource Label}" FontSize="9" />
                                                <TextBlock Text="{Binding Value}" Foreground="{StaticResource Text}"
                                                           FontFamily="{StaticResource FontLabel}" FontSize="13" FontWeight="SemiBold"
                                                           Margin="0,2,0,0" MaxWidth="260" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                <Button Content="EXPORT TXT" Style="{StaticResource GhostButton}"
                                        Command="{Binding ExportTxtCommand}" Width="130" Margin="0,0,10,0" />
                                <Button Content="EXPORT PDF" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ExportPdfCommand}" Width="130" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,22,0,16">
                            <Border Width="4" Height="18" Background="{StaticResource Red}" VerticalAlignment="Center" />
                            <TextBlock Text="COMPOSANTS DÉTECTÉS" Style="{StaticResource H2}" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding Components}" ItemTemplate="{StaticResource CardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- DETAIL -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30,26"
                              Visibility="{Binding ShowDetail, Converter={StaticResource BoolVis}}">
                    <StackPanel DataContext="{Binding SelectedComponent}">
                        <Grid Margin="0,0,0,22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="52" Height="52" Background="#FF101013"
                                    BorderBrush="{StaticResource Red}" BorderThickness="2">
                                <TextBlock Text="{Binding ShortCode}" Foreground="{StaticResource Red}"
                                           FontFamily="{StaticResource FontLabel}" FontWeight="Bold" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Category}" Style="{StaticResource Label}" />
                                <TextBlock Text="{Binding Name}" Style="{StaticResource H1}" FontSize="24" />
                            </StackPanel>
                            <Button Grid.Column="2" Content="‹ RETOUR" Style="{StaticResource GhostButton}"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.ShowOverviewCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Groups}" ItemTemplate="{StaticResource GroupTemplate}" />
                        <ItemsControl ItemsSource="{Binding SubComponents}" ItemTemplate="{StaticResource SubComponentTemplate}" />
                    </StackPanel>
                </ScrollViewer>

                <!-- BENCHMARKS -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30,26"
                              Visibility="{Binding ShowBenchmarks, Converter={StaticResource BoolVis}}">
                    <StackPanel DataContext="{Binding Benchmark}">
                        <TextBlock Text="BENCHMARKS &amp; STRESS" Style="{StaticResource H1}" />
                        <TextBlock Style="{StaticResource Label}" FontSize="13" FontWeight="Normal" Margin="0,4,0,0">
                            <Run Text="Mesure des performances —" />
                            <Run Text="{Binding Cores, Mode=OneWay}" Foreground="{StaticResource Red}" FontWeight="Bold" />
                            <Run Text="threads logiques" />
                        </TextBlock>

                        <!-- run control card -->
                        <Border Style="{StaticResource Card}" Margin="0,18,0,0">
                            <StackPanel>
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="▶ TOUT TESTER" Style="{StaticResource PrimaryButton}"
                                                Command="{Binding RunAllCommand}" Margin="0,0,10,0" />
                                        <Button Content="CPU" Style="{StaticResource GhostButton}" Width="86"
                                                Margin="0,0,8,0" Command="{Binding RunCpuCommand}" />
                                        <Button Content="MÉMOIRE" Style="{StaticResource GhostButton}" Width="100"
                                                Margin="0,0,8,0" Command="{Binding RunMemoryCommand}" />
                                        <Button Content="DISQUE" Style="{StaticResource GhostButton}" Width="94"
                                                Command="{Binding RunDiskCommand}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Content="ANNULER" Style="{StaticResource GhostButton}" Width="96" Margin="0,0,10,0"
                                                Command="{Binding CancelCommand}"
                                                Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}" />
                                        <TextBlock Text="{Binding Progress, StringFormat={}{0:0} %, Mode=OneWay}"
                                                   FontFamily="{StaticResource FontMetric}" FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource Pink}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                                <ProgressBar Style="{StaticResource Bar}" Value="{Binding Progress, Mode=OneWay}" Margin="0,14,0,0" />
                                <TextBlock Text="{Binding Status}" Style="{StaticResource Label}" FontWeight="Normal"
                                           Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- CPU STRESS -->
                        <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                            <StackPanel>
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="STRESS TEST CPU" Style="{StaticResource H2}" />
                                        <TextBlock Text="Charge maximale tous cœurs — surveille température &amp; throttling"
                                                   Style="{StaticResource Label}" FontWeight="Normal" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="DÉMARRER" Style="{StaticResource PrimaryButton}" Width="128"
                                                Command="{Binding StartStressCommand}"
                                                Visibility="{Binding IsStressing, Converter={StaticResource InvBoolVis}}" />
                                        <Button Content="ARRÊTER" Style="{StaticResource GhostButton}" Width="128"
                                                Command="{Binding StopStressCommand}"
                                                Visibility="{Binding IsStressing, Converter={StaticResource BoolVis}}" />
                                    </StackPanel>
                                </Grid>

                                <Border Background="{StaticResource Red}" Padding="12,8" Margin="0,14,0,0"
                                        Effect="{StaticResource RedGlowFx}"
                                        Visibility="{Binding ThrottleWarning, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="⚠ THROTTLING THERMIQUE DÉTECTÉ — la fréquence chute sous charge."
                                               Foreground="White" FontFamily="{StaticResource FontLabel}" FontWeight="Bold" FontSize="12.5" />
                                </Border>

                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- gauge -->
                                    <Border Grid.Column="0" Style="{StaticResource Tile}" Height="180">
                                        <Grid>
                                            <ctl:RadialGauge Value="{Binding StressTempValue}" Maximum="100" Thickness="12"
                                                             ArcBrush="{StaticResource Red}" TrackBrush="{StaticResource BorderDim}" />
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding StressTempValue, StringFormat={}{0:0}°, Mode=OneWay}"
                                                           FontFamily="{StaticResource FontMetric}" FontSize="34" FontWeight="Bold"
                                                           Foreground="{StaticResource Text}" HorizontalAlignment="Center" />
                                                <TextBlock Text="CPU PACKAGE" Style="{StaticResource Label}" FontSize="9"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- charts + tiles -->
                                    <StackPanel Grid.Column="2">
                                        <UniformGrid Columns="5">
                                            <StackPanel>
                                                <TextBlock Text="DURÉE" Style="{StaticResource Label}" FontSize="10" />
                                                <TextBlock Text="{Binding StressElapsed}" Style="{StaticResource Metric}" FontSize="18" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="TEMP" Style="{StaticResource Label}" FontSize="10" />
                                                <TextBlock Text="{Binding StressTemp}" Style="{StaticResource Metric}" FontSize="18" Foreground="{StaticResource Red}" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="TEMP MAX" Style="{StaticResource Label}" FontSize="10" />
                                                <TextBlock Text="{Binding StressMaxTemp}" Style="{StaticResource Metric}" FontSize="18" Foreground="{StaticResource Pink}" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="FRÉQ" Style="{StaticResource Label}" FontSize="10" />
                                                <TextBlock Text="{Binding StressClock}" Style="{StaticResource Metric}" FontSize="18" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="CHARGE" Style="{StaticResource Label}" FontSize="10" />
                                                <TextBlock Text="{Binding StressLoad}" Style="{StaticResource Metric}" FontSize="18" Margin="0,2,0,0" />
                                            </StackPanel>
                                        </UniformGrid>
                                        <TextBlock Text="THERMAL DYNAMICS" Style="{StaticResource Label}" FontSize="10" Margin="0,14,0,0" />
                                        <Border Background="#FF0A0A0C" BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                                                Height="120" Margin="0,6,0,0" Padding="4">
                                            <Grid>
                                                <ctl:TrendChart Values="{Binding LoadHistory}" LineBrush="#FF8A8F98" />
                                                <ctl:TrendChart Values="{Binding TempHistory}" LineBrush="{StaticResource Red}">
                                                    <ctl:TrendChart.AreaBrush>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#55E4002B" Offset="0" />
                                                            <GradientStop Color="#00E4002B" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </ctl:TrendChart.AreaBrush>
                                                </ctl:TrendChart>
                                            </Grid>
                                        </Border>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Border Width="14" Height="3" Background="{StaticResource Red}" VerticalAlignment="Center" />
                                            <TextBlock Text="TEMPÉRATURE (°C)" Style="{StaticResource Label}" FontSize="9" Margin="6,0,18,0" />
                                            <Border Width="14" Height="3" Background="{StaticResource TextMuted}" VerticalAlignment="Center" />
                                            <TextBlock Text="CHARGE (%)" Style="{StaticResource Label}" FontSize="9" Margin="6,0,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- GPU STRESS -->
                        <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                            <StackPanel>
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="STRESS TEST GPU" Style="{StaticResource H2}" />
                                        <TextBlock Text="Charge graphique soutenue — surveille température &amp; fréquence GPU"
                                                   Style="{StaticResource Label}" FontWeight="Normal" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="DÉMARRER" Style="{StaticResource PrimaryButton}" Width="128"
                                                Command="{Binding StartGpuStressCommand}"
                                                Visibility="{Binding IsGpuStressing, Converter={StaticResource InvBoolVis}}" />
                                        <Button Content="ARRÊTER" Style="{StaticResource GhostButton}" Width="128"
                                                Command="{Binding StopGpuStressCommand}"
                                                Visibility="{Binding IsGpuStressing, Converter={StaticResource BoolVis}}" />
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource Tile}" Height="180">
                                        <Grid>
                                            <ctl:RadialGauge Value="{Binding GpuTempValue}" Maximum="100" Thickness="12"
                                                             ArcBrush="{StaticResource Red}" TrackBrush="{StaticResource BorderDim}" />
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding GpuTempValue, StringFormat={}{0:0}°, Mode=OneWay}"
                                                           FontFamily="{StaticResource FontMetric}" FontSize="34" FontWeight="Bold"
                                                           Foreground="{StaticResource Text}" HorizontalAlignment="Center" />
                                                <TextBlock Text="GPU CORE" Style="{StaticResource Label}" FontSize="9"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="2">
                                        <UniformGrid Columns="5">
                                            <StackPanel>
                                                <TextBlock Text="DURÉE" Style="{StaticResource Label}" FontSize="10" />
                                                <TextBlock Text="{Binding GpuElapsed}" Style="{StaticResource Metric}" FontSize="18" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="TEMP" Style="{StaticResource Label}" FontSize="10" />
                                                <TextBlock Text="{Binding GpuTemp}" Style="{StaticResource Metric}" FontSize="18" Foreground="{StaticResource Red}" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="TEMP MAX" Style="{StaticResource Label}" FontSize="10" />
                                                <TextBlock Text="{Binding GpuMaxTemp}" Style="{StaticResource Metric}" FontSize="18" Foreground="{StaticResource Pink}" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="FRÉQ" Style="{StaticResource Label}" FontSize="10" />
                                                <TextBlock Text="{Binding GpuClock}" Style="{StaticResource Metric}" FontSize="18" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="CHARGE" Style="{StaticResource Label}" FontSize="10" />
                                                <TextBlock Text="{Binding GpuLoad}" Style="{StaticResource Metric}" FontSize="18" Margin="0,2,0,0" />
                                            </StackPanel>
                                        </UniformGrid>
                                        <TextBlock Text="THERMAL DYNAMICS" Style="{StaticResource Label}" FontSize="10" Margin="0,14,0,0" />
                                        <Border Background="#FF0A0A0C" BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                                                Height="120" Margin="0,6,0,0" Padding="4">
                                            <Grid>
                                                <ctl:TrendChart Values="{Binding GpuLoadHistory}" LineBrush="#FF8A8F98" />
                                                <ctl:TrendChart Values="{Binding GpuTempHistory}" LineBrush="{StaticResource Red}">
                                                    <ctl:TrendChart.AreaBrush>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#55E4002B" Offset="0" />
                                                            <GradientStop Color="#00E4002B" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </ctl:TrendChart.AreaBrush>
                                                </ctl:TrendChart>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- results -->
                        <StackPanel Orientation="Horizontal" Margin="0,22,0,16">
                            <Border Width="4" Height="18" Background="{StaticResource Red}" VerticalAlignment="Center" />
                            <TextBlock Text="RÉSULTATS" Style="{StaticResource H2}" Margin="10,0,10,0" VerticalAlignment="Center" />
                            <Button Content="EFFACER" Style="{StaticResource GhostButton}" Height="30" Width="90"
                                    Command="{Binding ClearCommand}" VerticalAlignment="Center" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding Results}" ItemTemplate="{StaticResource BenchResultTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
